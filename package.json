    "@vitest/coverage-v8": "^4.1.10",
    "@vue/runtime-core": "^3.5.39",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "prettier": "^3.9.5",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.0.0"
