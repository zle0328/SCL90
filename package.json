    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\""
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-components": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-h5": "3.0.0-alpha-1000920260626810",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "vue": "^3.5.39",
    "wot-design-uni": "^1.14.0"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-cli-shared": "3.0.0-alpha-1000920260626810",
    "@dcloudio/uni-stacktracey": "3.0.0-alpha-1000920260626810",
